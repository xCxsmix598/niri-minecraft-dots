layout {
    focus-ring {
        active-color "#ffb4a2"
        inactive-color "#a08c88"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb4a2"
        inactive-color "#a08c88"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb4a2"
        inactive-color "#a08c88"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb4a280"
    }
}

