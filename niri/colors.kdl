layout {
    focus-ring {
        active-color "#97d5a4"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#97d5a4"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#97d5a4"
        inactive-color "#8b938a"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#97d5a480"
    }
}

