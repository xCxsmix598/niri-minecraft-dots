layout {
    focus-ring {
        active-color "#ffb596"
        inactive-color "#a08d85"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb596"
        inactive-color "#a08d85"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb596"
        inactive-color "#a08d85"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb59680"
    }
}

