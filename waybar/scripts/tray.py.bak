import subprocess
import os


def on():
    process = subprocess.Popen(
        ['waybar', '-c', '/home/xyphe/.config/waybar/tray.jsonc'])
    os.system('echo on > /home/xyphe/.config/waybar/scripts/tray.state')
    os.system(
        f'echo {process.pid} > /home/xyphe/.config/waybar/scripts/tray.pid')


def off():
    tray_pid = subprocess.getoutput(
        'cat /home/xyphe/.config/waybar/scripts/tray.pid')
    os.system(f'kill -9 {tray_pid}')
    os.system('echo off > /home/xyphe/.config/waybar/scripts/tray.state')


if subprocess.getoutput('cat /home/xyphe/.config/waybar/scripts/tray.state') == "on":
    off()
    exit()
else:
    on()
    exit()
